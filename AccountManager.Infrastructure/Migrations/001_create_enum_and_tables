CREATE TYPE UserRole AS ENUM ('normal', 'admin');

CREATE TABLE table_users
(
    id    UUID PRIMARY KEY DEFAULT uuidv7(),
    email TEXT,
    role  UserRole,
    CONSTRAINT not_null_email NOT NULL email,
    CONSTRAINT check_email CHECK ( length(email) > 0 ),
    CONSTRAINT not_null_role NOT NULL role
);

CREATE TABLE table_passwords
(
    password TEXT,
    user_id  UUID,
    CONSTRAINT check_password CHECK ( length(password) > 0 ),
    CONSTRAINT unique_user_id UNIQUE (user_id),
    CONSTRAINT foreign_key_user_id FOREIGN KEY (user_id) REFERENCES table_users (id) ON DELETE RESTRICT
)