<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:AccountManager.Presentation.ViewModels.Pages.Gateway"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
    x:DataType="vm:GatewayViewModel"
    x:Class="AccountManager.Presentation.Views.Pages.Gateway.GatewayView">

    <Grid
        RowDefinitions="Auto, *"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch">

        <Menu
            Grid.Row="0"
            BorderBrush="LightGray"
            BorderThickness="0, 0, 0, 2">
            <MenuItem
                Header="Назад"
                Command="{Binding UndoCommand}"
                IsVisible="{Binding IsUndoButtonVisible}" />
        </Menu>

        <ContentControl
            Grid.Row="1"
            Padding="20"
            Content="{Binding CurrentPage}" />

    </Grid>
</UserControl>