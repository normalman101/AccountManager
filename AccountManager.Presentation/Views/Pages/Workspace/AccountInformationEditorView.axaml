<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:AccountManager.Presentation.ViewModels.Pages.Workspace"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
    x:DataType="vm:AccountInformationEditorViewModel"
    x:Class="AccountManager.Presentation.Views.Pages.Workspace.AccountInformationEditorView">

    <Grid
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        RowDefinitions="*, *, *, *"
        RowSpacing="20">

        <Grid
            Grid.Row="0"
            RowDefinitions="Auto, Auto"
            RowSpacing="10">

            <TextBlock
                Grid.Row="0"
                Text="Почта:" />

            <TextBox
                Grid.Row="1"
                HorizontalAlignment="Left"
                Width="250"
                Height="50"
                Text="example@mail.com"
                VerticalContentAlignment="Center" />

        </Grid>

        <Grid
            Grid.Row="1"
            RowDefinitions="Auto, Auto"
            RowSpacing="10">

            <TextBlock
                Grid.Row="0"
                Text="Пароль:" />

            <TextBox
                Grid.Row="1"
                HorizontalAlignment="Left"
                Width="250"
                Height="50"
                Text="example@mail.com"
                PasswordChar="●"
                VerticalContentAlignment="Center" />

        </Grid>
        
        <Grid
            Grid.Row="2"
            RowDefinitions="Auto, Auto"
            RowSpacing="10">

            <TextBlock
                Grid.Row="0"
                Text="Роль:" />

            <ComboBox
                Grid.Row="1"
                SelectedIndex="0">
                <ComboBoxItem>Обычный</ComboBoxItem>
                <ComboBoxItem>Админ</ComboBoxItem>
            </ComboBox>

        </Grid>

        <Grid
            Grid.Row="3"
            ColumnDefinitions="*, *">

            <Button
                Grid.Column="0"
                HorizontalAlignment="Center"
                Width="250"
                Height="50"
                Content="Сохранить"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center" />

            <Button
                Grid.Column="1"
                HorizontalAlignment="Center"
                Width="250"
                Height="50"
                Content="Отменить"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center" />

        </Grid>

    </Grid>

</UserControl>