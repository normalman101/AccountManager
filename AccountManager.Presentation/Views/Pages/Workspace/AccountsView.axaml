<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:AccountManager.Presentation.ViewModels.Pages.Workspace"
    xmlns:m="using:AccountManager.Application.DTOs"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
    x:DataType="vm:AccountsViewModel"
    x:Class="AccountManager.Presentation.Views.Pages.Workspace.AccountsView">

    <Grid
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        RowDefinitions="2*, *"
        RowSpacing="20">

        <ListBox
            ItemsSource="{Binding Accounts}"
            SelectedItem="{Binding Account}"
            Grid.Row="0">

            <ListBox.ItemTemplate>

                <DataTemplate x:DataType="m:AccountDto">

                    <Grid ColumnDefinitions="*, *">

                        <TextBlock
                            Grid.Column="0"
                            Text="{Binding Email}"/>

                        <TextBlock
                            Grid.Column="1" 
                            Text="{Binding Role}"/>

                    </Grid>

                </DataTemplate>

            </ListBox.ItemTemplate>

        </ListBox>
        
        
        <Grid 
            Grid.Row="1"
            ColumnDefinitions="*, *">
            
            <Button
                Grid.Column="0"
                HorizontalAlignment="Center"
                Width="250"
                Height="50"
                Content="Изменить"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Command="{Binding EditCommand}"/>
            
            <Button
                Grid.Column="1"
                HorizontalAlignment="Center"
                Width="250"
                Height="50"
                Content="Удалить"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center" 
                Command="{Binding DeleteCommand}"/>
            
        </Grid>

    </Grid>

</UserControl>